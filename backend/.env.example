# SwiftTrip Backend - Environment Variables Template
# Copy this file to .env and fill in your personal credentials if needed.

# --- LLM configuration ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- Travel API configuration ---
AMADEUS_API_KEY=your_amadeus_api_key_here
AMADEUS_API_SECRET=your_amadeus_api_secret_here

# --- Email configuration (Mailtrap Sandbox) ---
# Optional: Leave blank to use the shared developer sandbox.
MAILTRAP_USER=
MAILTRAP_PASSWORD=
